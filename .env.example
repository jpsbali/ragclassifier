USE_OPENROUTER=true

# OpenAI and OpenRouter API keys and base URLs
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

OPENROUTER_BASE_URL=https://api.openrouter.ai/v1
OPENROUTER_API_KEY=

# Supervisor
SUPERVISOR_BASE_URL=
SUPERVISOR_API_KEY=
SUPERVISOR_MODEL=
OPENAI_SUPERVISOR_MODEL=gpt-4.1
OPENAI_SUPERVISOR_MODEL_COST_INPUT_TOKENS=2.00
OPENAI_SUPERVISOR_MODEL_COST_OUTPUT_TOKENS=8.00
OPENROUTER_SUPERVISOR_MODEL=google/gemini-3-flash-preview
OPENROUTER_SUPERVISOR_MODEL_COST_INPUT_TOKENS=0.50
OPENROUTER_SUPERVISOR_MODEL_COST_OUTPUT_TOKENS=3.00
SUPERVISOR_TEMPERATURE=0.1
SUPERVISOR_TIMEOUT_S=60

# Agent A
AGENT_A_BASE_URL=
AGENT_A_API_KEY=
AGENT_A_MODEL=
OPENAI_AGENT_A_MODEL=gpt-4.1-mini
OPENAI_AGENT_A_MODEL_COST_INPUT_TOKENS=0.40
OPENAI_AGENT_A_MODEL_COST_OUTPUT_TOKENS=1.60
OPENROUTER_AGENT_A_MODEL=x-ai/grok-4.1-fast
OPENROUTER_AGENT_A_MODEL_COST_INPUT_TOKENS=0.20
OPENROUTER_AGENT_A_MODEL_COST_OUTPUT_TOKENS=0.50
AGENT_A_TEMPERATURE=0.0
AGENT_A_TIMEOUT_S=60

# Agent B
AGENT_B_BASE_URL=
AGENT_B_API_KEY=
AGENT_B_MODEL=
OPENAI_AGENT_B_MODEL=gpt-4o-mini
OPENAI_AGENT_B_MODEL_COST_INPUT_TOKENS=0.15
OPENAI_AGENT_B_MODEL_COST_OUTPUT_TOKENS=0.60
OPENROUTER_AGENT_B_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_AGENT_B_MODEL_COST_INPUT_TOKENS=3.00
OPENROUTER_AGENT_B_MODEL_COST_OUTPUT_TOKENS=15.00
AGENT_B_TEMPERATURE=0.0
AGENT_B_TIMEOUT_S=60

# Evaluator Agent
EVALUATOR_BASE_URL=
EVALUATOR_API_KEY=
EVALUATOR_MODEL=
OPENAI_EVALUATOR_MODEL=gpt-4o
OPENAI_EVALUATOR_MODEL_COST_INPUT_TOKENS=2.50
OPENAI_EVALUATOR_MODEL_COST_OUTPUT_TOKENS=10.00
OPENROUTER_EVALUATOR_MODEL=google/gemini-pro-1.5
OPENROUTER_EVALUATOR_MODEL_COST_INPUT_TOKENS=1.25
OPENROUTER_EVALUATOR_MODEL_COST_OUTPUT_TOKENS=3.75
EVALUATOR_TEMPERATURE=0.0
EVALUATOR_TIMEOUT_S=60

# TCH Cost Matrix (Penalty for Misclassification)
COST_TRUE_RESTRICTED_PRED_CONFIDENTIAL=40.0
COST_TRUE_RESTRICTED_PRED_PUBLIC=100.0
COST_TRUE_CONFIDENTIAL_PRED_RESTRICTED=3.0
COST_TRUE_CONFIDENTIAL_PRED_PUBLIC=15.0
COST_TRUE_PUBLIC_PRED_RESTRICTED=0.5
COST_TRUE_PUBLIC_PRED_CONFIDENTIAL=2.0
COST_RISK_THRESHOLD=5.0

# Consensus behavior
CONSENSUS_MIN_CONFIDENCE=0.90
CONSENSUS_MAX_ROUNDS=3

# File processing
MAX_FILE_SIZE_MB=10

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ragclassifier

# Risk Evaluation
# If set to true, the application will perform a cost-based risk analysis on each
# classification. If the expected cost of an error exceeds the risk threshold,
# the item will be flagged for human review.
ENABLE_RISK_EVALUATION=true

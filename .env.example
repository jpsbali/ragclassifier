USE_OPENROUTER=true

# OpenAI and OpenRouter API keys and base URLs
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

OPENROUTER_BASE_URL=https://api.openrouter.ai/v1
OPENROUTER_API_KEY=

# Supervisor
SUPERVISOR_BASE_URL=
SUPERVISOR_API_KEY=
SUPERVISOR_MODEL=
OPENAI_SUPERVISOR_MODEL=gpt-4.1
OPENROUTER_SUPERVISOR_MODEL=google/gemini-3-flash-preview
SUPERVISOR_TEMPERATURE=0.1
SUPERVISOR_TIMEOUT_S=60

# Agent A
AGENT_A_BASE_URL=
AGENT_A_API_KEY=
AGENT_A_MODEL=
OPENAI_AGENT_A_MODEL=gpt-4.1-mini
OPENROUTER_AGENT_A_MODEL=x-ai/grok-4.1-fast
AGENT_A_TEMPERATURE=0.0
AGENT_A_TIMEOUT_S=60

# Agent B
AGENT_B_BASE_URL=
AGENT_B_API_KEY=
AGENT_B_MODEL=
OPENAI_AGENT_B_MODEL=gpt-4o-mini
OPENROUTER_AGENT_B_MODEL=anthropic/claude-sonnet-4.5
AGENT_B_TEMPERATURE=0.0
AGENT_B_TIMEOUT_S=60

# Consensus behavior
CONSENSUS_MIN_CONFIDENCE=0.90
CONSENSUS_MAX_ROUNDS=3

# File processing
MAX_FILE_SIZE_MB=10

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ragclassifier
